         | SpellId('Projectile_BladeFlourish_Defensive')
         | SpellId('Target_BladeFlourish_Mobile')
         | SpellId('Projectile_BladeFlourish_Mobile')
         | SpellId('Zone_BladeFlourish_Slashing')
