function Goon_ConstitutionModEquals(value)
    return ConditionResult(GetModifier(context.Source.Constitution) == value)
end

function Goon_ConstitutionModGreaterThan(value)
    return ConditionResult(GetModifier(context.Source.Constitution) > value)
end

function Goon_ConstitutionModLessThan(value)
    return ConditionResult(GetModifier(context.Source.Constitution) < value)
end

function Goon_ConstitutionModGreaterThanOrEqual(value)
    return ConditionResult(GetModifier(context.Source.Constitution) >= value)
end

function Goon_ConstitutionModLessThanOrEqual(value)
    return ConditionResult(GetModifier(context.Source.Constitution) <= value)
end

