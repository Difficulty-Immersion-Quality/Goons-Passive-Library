-- Check for ability used in attack roll
function Goon_AttackAbility(ability)
    return IsAttack() & ConditionResult(context.HitDescription.AttackAbility == ability)
end

-- Check for magical weapon properties on attacking weapon
function Goon_AttackWeaponIsMagical(entity)
    entity = context.Source or entity
    return HasWeaponProperty(WeaponProperties.Magical, GetAttackWeapon(entity))
end

-- Disguise Self check
function Goon_IsDisguiseSelfSpell()
    return SpellId('Shout_DisguiseSelf') 
    | SpellId('Shout_DisguiseSelf_Tiefling_Male') | SpellId('Shout_DisguiseSelf_Tiefling_Female') 
    | SpellId('Shout_DisguiseSelf_Drow_Male') | SpellId('Shout_DisguiseSelf_Drow_Female') 
    | SpellId('Shout_DisguiseSelf_Human_Male') | SpellId('Shout_DisguiseSelf_Human_Female') 
    | SpellId('Shout_DisguiseSelf_Githyanki_Male') | SpellId('Shout_DisguiseSelf_Githyanki_Female') 
    | SpellId('Shout_DisguiseSelf_Dwarf_Male') | SpellId('Shout_DisguiseSelf_Dwarf_Female') 
    | SpellId('Shout_DisguiseSelf_Elf_Male') | SpellId('Shout_DisguiseSelf_Elf_Female') 
    | SpellId('Shout_DisguiseSelf_HalfElf_Male') | SpellId('Shout_DisguiseSelf_HalfElf_Female') 
    | SpellId('Shout_DisguiseSelf_Halfling_Male') | SpellId('Shout_DisguiseSelf_Halfling_Female') 
    | SpellId('Shout_DisguiseSelf_Dragonborn_Male') | SpellId('Shout_DisguiseSelf_Dragonborn_Female') 
    | SpellId('Shout_DisguiseSelf_HalfOrc_Male') | SpellId('Shout_DisguiseSelf_HalfOrc_Female') 
    | SpellId('Shout_DisguiseSelf_Gnome_Male') | SpellId('Shout_DisguiseSelf_Gnome_Female') 
    | SpellId('Shout_DisguiseSelf_Human_Strong_Male') | SpellId('Shout_DisguiseSelf_Human_Strong_Female') 
    | SpellId('Shout_DisguiseSelf_Drow_Strong_Male') | SpellId('Shout_DisguiseSelf_Drow_Strong_Female') 
    | SpellId('Shout_DisguiseSelf_Elf_Strong_Male') | SpellId('Shout_DisguiseSelf_Elf_Strong_Female') 
    | SpellId('Shout_DisguiseSelf_HalfElf_Strong_Male') | SpellId('Shout_DisguiseSelf_HalfElf_Strong_Female') 
    | SpellId('Shout_DisguiseSelf_Tiefling_Strong_Male') | SpellId('Shout_DisguiseSelf_Tiefling_Strong_Female')
end

-- Surface checks
function Goon_IsInWaterSurface(entity)
    local entity = entity or context.Target
    return InSurface('SurfaceBlood', entity)
    | InSurface('SurfaceBloodElectrified', entity)
    | InSurface('SurfaceBloodFrozen', entity)
    | InSurface('SurfaceWater', entity)
    | InSurface('SurfaceWaterElectrified', entity)
    | InSurface('SurfaceWaterFrozen', entity)
    | InSurface('SurfaceDeepWater', entity)
    | InSurface('SurfaceDeepWaterRunning', entity)
    | InSurface('Sewer', entity)
end

function Goon_IsInFreezableSurface(entity)
    local entity = entity or context.Target
    return InSurface('SurfaceWater', entity)
    | InSurface('SurfaceWaterElectrified', entity)
    | InSurface('SurfaceBlood', entity)
    | InSurface('SurfaceAlcohol', entity)
    | InSurface('SurfaceAcid', entity)
end

-- ==================================== String Lookups - JuuM ====================================
-- Conditions created by JuuM that do string lookups that can be used for better upcast checking

-- JM_HasStringInSpellId('Spell1','Spell2')
-- Original name: function JM_HasStringInSpellId(...)
function Goon_HasStringInSpellId(...)
    local strings = {...}
    local spellId = context.SpellModificationDescription.SpellId
    if spellId ~= "" then
        for _,v in ipairs(strings) do
            if string.find(spellId,v) then
                return ConditionResult(true)
            end
        end
    end
    return ConditionResult(false)
end

-- JM_SpellOrUpcastOf('Spell1','Spell2')
-- Original name: function JM_SpellOrUpcastOf(...)
function Goon_SpellOrUpcastOf(...)
    local spells = {...}
    local spellLevel = context.HitDescription.SpellLevel
    local spellPowerLevel = context.HitDescription.SpellPowerLevel
    for _,v in ipairs(spells) do
        local spell = v
        if spellPowerLevel ~= spellLevel then
            spell = spell .. string.format("_%i",spellPowerLevel)
        end
        if SpellId(spell).Result then
            return ConditionResult(true)
        end
    end
    return ConditionResult(false)
end

