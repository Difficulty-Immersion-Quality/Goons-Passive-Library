-- Character size checks
function Goon_IsSize(size, entity)
    entity = entity or context.Target
    return ConditionResult(entity.Size ~= Size.None and entity.Size.value == size.value)
end

function Goon_IsSizeGreaterThan(size, entity)
    entity = entity or context.Target
    return ConditionResult(entity.Size ~= Size.None and entity.Size.value > size.value)
end

function Goon_IsSizeLessThan(size, entity)
    entity = entity or context.Target
    return ConditionResult(entity.Size ~= Size.None and entity.Size.value < size.value)
end

function Goon_IsSizeGreaterThanOrEqual(size, entity)
    entity = entity or context.Target
    return ConditionResult(entity.Size ~= Size.None and entity.Size.value >= size.value)
end

function Goon_IsSizeLessThanOrEqual(size, entity)
    entity = entity or context.Target
    return ConditionResult(entity.Size ~= Size.None and entity.Size.value <= size.value)
end

-- Class level checks
function Goon_ClassLevelEquals(level, class, entity)
    local entity = entity or context.Source
    return ConditionResult(entity.GetClassLevel(class) == level)
end

function Goon_ClassLevelGreaterThan(level, class, entity)
    local entity = entity or context.Source
    return ConditionResult(entity.GetClassLevel(class) > level)
end

function Goon_ClassLevelLessThan(level, class, entity)
    local entity = entity or context.Source
    return ConditionResult(entity.GetClassLevel(class) < level)
end

function Goon_ClassLevelGreaterThanOrEqual(level, class, entity)
    local entity = entity or context.Source
    return ConditionResult(entity.GetClassLevel(class) >= level)
end

function Goon_ClassLevelLessThanOrEqual(level, class, entity)
    local entity = entity or context.Source
    return ConditionResult(entity.GetClassLevel(class) <= level)
end

function Goon_IsClassLevelEqualOrBetween(value, value2, entity)
    local entity = entity or context.Source
    return Goon_ClassLevelGreaterThanOrEqual(value, entity) & Goon_ClassLevelLessThanOrEqual(value2, entity)
end

