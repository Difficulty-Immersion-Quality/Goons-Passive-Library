         | IsSpellChildOrVariantFromContext('Target_Banishment') 
         | SpellId('Target_Smite_Banishing') 
         | IsSpellChildOrVariantFromContext('Target_Smite_Banishing') 
         | SpellId('Projectile_Smite_Banishing') 
         | IsSpellChildOrVariantFromContext('Projectile_Smite_Banishing') 
         | SpellId('Projectile_ArcaneShot_BanishingArrow')
end

-- ==================================== Conditions to be used in interrupts or passives that seek to trigger from spells with set "DamageType"
-- Handles cantrips (or whatever other conditional stuff) that don't deal damage until level 5 and need exclusion from shit
-- Disallows spells with a DamageType but no DealDamage functors from triggering things improperly
-- TODO: Track down all cantrips that only directly deal damage after level 5
-- TODO: Expand for handling of edge cases
-- TODO: Allow statuses from spells such as Booming Blades conditional explosion damage to function? (case by case basis)
-- TODO: Replace every instance of "HasFunctor(StatsFunctorType.DealDamage)" with this function, and include it wherever "SpellDamageTypeIs" is called (barring exceptions)

function Goon_IsSpellDealingFunctorDamage()
    return HasFunctor(StatsFunctorType.DealDamage) & (Goon_CharacterLevelEqualToOrGreaterThan_5() | 
           ~(SpellId('Target_BoomingBlade')
           | IsSpellChildOrVariantFromContext('Target_BoomingBlade')
           | SpellId('Target_BoomingBlade_ClassSpell')
           | IsSpellChildOrVariantFromContext('Target_BoomingBlade_ClassSpell')
           | SpellId('Target_BoomingBlade_5e')
           | IsSpellChildOrVariantFromContext('Target_BoomingBlade_5e')))
end

-- ==================================== Weapon/armour equipped checks ====================================

function Goon_Dueling_Check(entity)
    entity = entity or context.Target
    local hasNonVersatileWeapon = WieldingWeapon('Melee', false, true, entity) & ~WieldingWeapon('Versatile', false, true, entity) & ~WieldingWeapon('Twohanded', false, true, entity) & ~WieldingWeapon('Melee', true, true, entity)
    local hasVersatileWeapon = WieldingWeapon('Versatile', false, true, entity) & WieldingWeapon('Melee', false, true, entity) & HasShieldEquipped(entity)
    return hasNonVersatileWeapon | hasVersatileWeapon
end

-- This is exact same as the vanilla DualWielder() khn function but putting this here for completeness
function Goon_DualWielding_Check(entity)
    entity = entity or context.Target
    return WieldingWeapon('Melee', false, true, entity) & WieldingWeapon('Melee', true, true, entity)
end

function Goon_GreatWeapon_Check(entity)
    entity = entity or context.Target
    local hasTwohandedWeapon = WieldingWeapon('Twohanded', false, true, entity) & WieldingWeapon('Melee', false, true, entity)
    local hasVersatileWeapon = WieldingWeapon('Versatile', false, true, entity) & ~WieldingWeapon('Melee', true, true, entity) & ~HasShieldEquipped(entity)
    return hasTwohandedWeapon | hasVersatileWeapon
end

-- Use in conjunction with Goon_IsPolearm() check (which only checks the active weapon) to reasonably cover all polearm-wielding possibilities for NPCs at least
function Goon_Polearm_Check(entity)
    entity = entity or context.Target
    return WieldingWeapon('Reach', false, true, entity)
end

function Goon_Bow_Check(entity)
    entity = entity or context.Target
    return WieldingWeapon('Ammunition', false, true, entity)
end

function Goon_Crossbow_Check(entity)
    entity = entity or context.Target
    WieldingWeapon('Loading', false, true, entity)
end

function Goon_HasLightArmor(entity)
    entity = entity or context.Target
    local armor = GetActiveArmor(entity)
    return IsOfProficiencyGroup("LightArmor", armor)
end

-- Alternative light armor check matching how it's checked in vanilla
function Goon_HasLightArmorAlt(entity)
    entity = entity or context.Target
    local armor = GetActiveArmor(entity)
    local hasLightArmor = armor.ArmorType == ArmorType.Padded or armor.ArmorType == ArmorType.Leather or armor.ArmorType == ArmorType.StuddedLeather
    return ConditionResult(hasLightArmor)
end

